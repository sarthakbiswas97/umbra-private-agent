# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/umbra_agent
REDIS_URL=redis://localhost:6380

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com
AGENT_KEYPAIR_PATH=~/.config/solana/id.json
DECISION_PROGRAM_ID=

# Umbra Service
UMBRA_SERVICE_URL=http://localhost:8002
UMBRA_NETWORK=devnet
UMBRA_RPC_URL=https://api.devnet.solana.com
UMBRA_RPC_SUBSCRIPTIONS_URL=wss://api.devnet.solana.com
UMBRA_INDEXER_URL=https://utxo-indexer.api-devnet.umbraprivacy.com

# Token Mints (Solana)
SOL_MINT=So11111111111111111111111111111111111111112
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# Market Data
BIRDEYE_API_KEY=

# Agent Config
AGENT_NAME=Umbra-Alpha
MAX_POSITION_SIZE=0.05
MAX_DAILY_LOSS=0.03
MAX_DRAWDOWN=0.10
TRADE_INTERVAL_SECONDS=60

# ML Model
MODEL_PATH=ml/models/model_bundle_latest.joblib
PREDICTION_THRESHOLD=0.65
CONFIDENCE_THRESHOLD=0.55

# API
API_HOST=0.0.0.0
API_PORT=8001
